{
  "name": "html-preview-tools",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "ブラウザ上でHTMLをリアルタイム編集・プレビューできるWebツール群（ビルド不要・オフライン動作）",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "vendor": "node scripts/vendor.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.56",
    "@vitest/coverage-v8": "^4.1.8",
    "codemirror": "^5.65.7",
    "eslint": "^10.4.1",
    "feather-icons": "^4.29.1",
    "globals": "^17.6.0",
    "js-beautify": "^1.15.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "vitest": "^4.1.8"
  }
}
